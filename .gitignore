# Anchored to the repo root with a leading slash — bare `target/` would also
# hide case-equivalent paths like ext/llvm-project/llvm/lib/Target/ on
# case-insensitive filesystems (e.g. NTFS), silently dropping ~2500 LLVM
# source files from clones.
/target/

.vscode/
.idea/

ptx/lib/zluda_ptx_impl.ll

# Local Claude Code session permissions (never share)
.claude/settings.local.json

# Local dev / debug artifacts
*.log
run_xtask_debug.log

# Built release zips (live as GitHub Release attachments, not in the repo)
/exstar-on-zluda-v*-windows-x64.zip

# Planning / debugging notes / sitreps live in the sibling zluda-exstar-archive repo,
# not in this public-facing repo.
docs/plans/
docs/superpowers/
AGENTS.md
